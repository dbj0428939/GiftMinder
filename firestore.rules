rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function validHandle(handle) {
      return handle.matches('^[a-z0-9_]{3,20}$');
    }

    function currentUserHandle() {
      return isSignedIn()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userId is string
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userId
        : "";
    }

    function isInvitedToEvent(eventData) {
      return eventData.invitedUserHandles is list
             && currentUserHandle() != ""
             && currentUserHandle() in eventData.invitedUserHandles;
    }

    function inviteStatusForCurrentUser(eventData) {
      return eventData.inviteStatuses is map
             && currentUserHandle() != ""
             && eventData.inviteStatuses[currentUserHandle()] is string
        ? eventData.inviteStatuses[currentUserHandle()]
        : "pending";
    }

    function isInviteRemoved(eventData) {
      return eventData.removedInviteHandles is list
             && currentUserHandle() != ""
             && currentUserHandle() in eventData.removedInviteHandles;
    }

    function isActiveInvite(eventData) {
      return isInvitedToEvent(eventData)
             && !isInviteRemoved(eventData)
             && inviteStatusForCurrentUser(eventData) != "declined"
             && inviteStatusForCurrentUser(eventData) != "removed";
    }

    function isRemovedForCurrentUser(eventData) {
      return eventData.removedForUserIds is list
             && request.auth.uid in eventData.removedForUserIds;
    }

    function isAttendingEvent(eventData) {
      return eventData.attendingUserIds is list
             && request.auth.uid in eventData.attendingUserIds;
    }

    function canViewEvent(eventData) {
      return isSignedIn()
             && !isRemovedForCurrentUser(eventData)
             && (
               eventData.organizerId == request.auth.uid
               || isActiveInvite(eventData)
               || isAttendingEvent(eventData)
               || eventData.visibility == "Public"
             );
    }

    function canContributeEvent(eventData) {
      return isSignedIn()
             && !isRemovedForCurrentUser(eventData)
             && (
               eventData.organizerId == request.auth.uid
               || isActiveInvite(eventData)
               || isAttendingEvent(eventData)
             );
    }

    function ownsContact(contactId) {
      return isSignedIn()
             && exists(/databases/$(database)/documents/contacts/$(contactId))
             && get(/databases/$(database)/documents/contacts/$(contactId)).data.userId == request.auth.uid;
    }

    // Public handle lookup is required for availability checks during signup.
    match /usernames/{handle} {
      allow read: if true;

      allow create: if isSignedIn()
                    && validHandle(handle)
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.userId == handle;

      allow update: if isSignedIn()
                    && validHandle(handle)
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.userId == handle;

      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if isSignedIn();

      allow create, update: if isOwner(uid)
                            && request.resource.data.uid == uid;
    }

    // Contacts are user-owned documents
    match /contacts/{contactId} {
      allow read, create, update, delete: if isSignedIn()
                                           && request.resource.data.userId == request.auth.uid;

      allow read: if isSignedIn()
                  && resource.data.userId == request.auth.uid;

      // Gifts subcollection under each contact
      match /gifts/{giftId} {
        allow read: if isSignedIn()
                    && (
                      ownsContact(contactId)
                      || resource.data.ownerUserId == request.auth.uid
                    );

        allow create: if isSignedIn()
                      && (
                        ownsContact(contactId)
                        || request.resource.data.ownerUserId == request.auth.uid
                      )
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && (request.resource.data.status == "wishlist" || request.resource.data.status == "purchased");

        allow update, delete: if isSignedIn()
                              && (
                                ownsContact(contactId)
                                || resource.data.ownerUserId == request.auth.uid
                              );
      }
    }

    // Notification sent records are Cloud Function managed
    match /notificationsSent/{recordId} {
      allow read: if isSignedIn()
                  && resource.data.userId == request.auth.uid;

      // Cloud Functions write these; client cannot write directly
      allow write: if false;
    }

    match /networkEvents/{eventId} {
      allow read: if canViewEvent(resource.data);

      allow create: if isSignedIn()
                    && request.resource.data.organizerId == request.auth.uid;

      allow update: if isSignedIn()
                    && (
                      resource.data.organizerId == request.auth.uid
                      || isInvitedToEvent(resource.data)
                      || isAttendingEvent(resource.data)
                    );

      allow delete: if isSignedIn()
                    && resource.data.organizerId == request.auth.uid;

      match /messages/{messageId} {
        allow read, create: if canContributeEvent(get(/databases/$(database)/documents/networkEvents/$(eventId)).data);

        allow update, delete: if false;
      }
    }

    match /publicPosts/{postId} {
      allow read, create, update, delete: if isSignedIn();

      match /comments/{commentId} {
        allow read, create, update, delete: if isSignedIn();
      }
    }

    // Keep app data private to authenticated users by default.
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
